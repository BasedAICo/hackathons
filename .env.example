# Copy to .env for local overrides (not committed).
# BioVault uses separate env files per service — see also:
#   backend/.env.example
#   frontend/.env.example

# Backend (Render / split deploy)
# CORS_ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app
# DEMO_ALLOW_ALL_CORS=false
# BIOVAULT_DB=/var/data/biovault.db

# Frontend (split deploy — Vite bakes at build time)
# VITE_API_BASE_URL=http://localhost:8000
